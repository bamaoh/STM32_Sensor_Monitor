# ==============================================================================
# STM32CubeIDE / Eclipse Project .gitignore
# ==============================================================================

# Build output
**/Debug/
**/Release/

# Eclipse / STM32CubeIDE workspace metadata
.metadata/
**/.settings/

# IDE launch configs
*.launch

# Compiled objects
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.list

# STM32CubeIDE specific
*.cfg
*.ld.bak

# STM32CubeMX backup
*.ioc.bak

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Datasheets (large PDF files)
**/Docs/Datasheets/